# ============================================================================
# Hames — Environment Variables Example
# ============================================================================
# Copy this file to .env (NEVER commit .env). Fill in only the keys you need —
# Hames degrades gracefully when optional integrations are missing.
#
# Required for nothing: Hames core (kernel, hooks, agents) runs without any
# of these. They unlock specific Arsenal tools.
# ============================================================================

# ─── AI Specialist (openai_specialist.py) ───────────────────────────────────
OPENAI_API_KEY=

# ─── Web Search (perplexity_tool.js) ────────────────────────────────────────
PERPLEXITY_API_KEY=

# ─── Notion (notion_tool.js) ────────────────────────────────────────────────
# Internal integration token: https://www.notion.so/my-integrations
NOTION_KEY=

# ─── Google Maps (google_tool.js) ───────────────────────────────────────────
GOOGLE_MAPS_KEY=

# ─── Naver Ads / Keyword Tool (naver_keyword_tool.js) ───────────────────────
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=
NAVER_AD_CUSTOMER_ID=

# ─── Optional: ElevenLabs TTS, additional research APIs ─────────────────────
ELEVENLABS_API_KEY=
CORE_AC_UK_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
